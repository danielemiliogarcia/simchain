.env

# Rust build artifacts. The workspace uses a single target/ at the repo root;
# the broad `target/` guards against stray per-crate target dirs too.
/target/
**/target/
**/*.rs.bk
*.pdb

# Cargo.lock is intentionally committed: these tools are binaries for a
# reproducible test network, so the lockfile is tracked (do NOT ignore it).

# Chain snapshots (./scripts/snapshot.sh): multi-MB machine-local archives
/snapshots/

# Scenario result artifacts.
/results/

# Control-plane state (token, durable desired state, job metadata/results).
/.simchain-control/*
!/.simchain-control/.gitkeep

# worktrees
.worktrees/
