.env

# Rust build artifacts. The workspace uses a single target/ at the repo root;
# the broad `target/` guards against stray per-crate target dirs too.
/target/
**/target/
**/*.rs.bk
*.pdb

# Cargo.lock is intentionally committed: the three tools are binaries for a
# reproducible test network, so the lockfile is tracked (do NOT ignore it).

# Chain snapshots (./scripts/snapshot.sh): multi-MB machine-local archives
/snapshots/

# spam-burst.sh temp scenarios (repo root so the container's /workspace mount
# sees them; removed by the script's EXIT trap, but a SIGKILL leaves strays)
.spam-burst.*

# Panel-generated files (bind-mounted from btc-simnet-panel): the API bearer
# token (secret, mode 0600) and the apply flock file
.panel-token
.env.panel.lock

# worktrees
.worktrees/
