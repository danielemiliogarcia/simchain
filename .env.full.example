###############################################################################
# Simchain settings, COMPLETE template. For the short everyday version use
# .env.example; every setting is documented in SETTINGS.md.
# Every variable here is OPTIONAL: docker-compose.yml carries the same
# defaults, so a missing variable (or a missing .env file) still works.
###############################################################################

## Bitcoin node image ---------------------------------------------------------
# Default: official image pulled from the registry.
BTC_IMAGE=bitcoin/bitcoin:29.0
# To use the locally built image instead, run ./build-bitcoin.sh and set:
# BTC_IMAGE=simchainbitcoinnode:29.0

# Bitcoin Core version used by ./build-bitcoin.sh when building the local image
BITCOIN_VERSION=29.0

## RPC credentials (shared by all nodes and tools) ----------------------------
BTC_RPC_USER=foo
BTC_RPC_PASS=rpcpassword

## Host port mappings ---------------------------------------------------------
NODE1_RPC_PORT=18443
NODE1_P2P_PORT=18444
NODE2_RPC_PORT=28443
NODE2_P2P_PORT=28444

## ZMQ notifications (node1 and node2) ----------------------------------------
# Both nodes publish all five bitcoind ZMQ topics (rawblock, rawtx,
# hashblock, hashtx, sequence) so ZMQ consumers (LND/CLN, indexers,
# watchers) can run against the simnet. These variables only change the HOST
# port mappings; inside the compose network the publishers always listen on
# 28332-28336. Smoke test in the README.
NODE1_ZMQ_RAWBLOCK_PORT=28332
NODE1_ZMQ_RAWTX_PORT=28333
NODE1_ZMQ_HASHBLOCK_PORT=28334
NODE1_ZMQ_HASHTX_PORT=28335
NODE1_ZMQ_SEQUENCE_PORT=28336
NODE2_ZMQ_RAWBLOCK_PORT=38332
NODE2_ZMQ_RAWTX_PORT=38333
NODE2_ZMQ_HASHBLOCK_PORT=38334
NODE2_ZMQ_HASHTX_PORT=38335
NODE2_ZMQ_SEQUENCE_PORT=38336

## Container-internal RPC endpoints -------------------------------------------
# URLs the helper tools (mining controller, spammer) use to reach the nodes
# inside the compose network. Only change them if you rename the node
# services or point the tools at other nodes.
NODE1_RPC_URL=http://btc-simnet-node1:18443
NODE2_RPC_URL=http://btc-simnet-node2:18443
NODE3_RPC_URL=http://btc-simnet-node3:18443

## Node policy ----------------------------------------------------------------
# The three fee settings look similar but act at different points:
#
# MIN_RELAY_TX_FEE (-minrelaytxfee, BTC/kvB): the NODE's floor. Minimum
# feerate for the node to accept a transaction into its mempool and relay
# it to peers. Transactions paying below this are rejected on arrival.
MIN_RELAY_TX_FEE=0.00001
# FALLBACK_FEE (-fallbackfee, BTC/kvB): the WALLET's guess. Feerate the
# wallet uses when fee estimation has no data yet, which is always the case
# on a fresh regtest chain. Without it, sendtoaddress fails with
# "Fee estimation failed". Must be >= MIN_RELAY_TX_FEE or the wallet
# creates transactions its own node refuses to relay.
FALLBACK_FEE=0.0001
# MAX_TX_FEE (-maxtxfee, whole BTC, an amount, not a rate): the WALLET's
# safety cap. A wallet transaction paying more total fee than this aborts.
# Set absurdly high here so spam volume never trips it; on mainnet the
# default is 0.1 BTC.
MAX_TX_FEE=10000000
# node1 wallet is disabled by default: node1 mimics a 3rd-party production
# endpoint where there is no hot wallet online, the user manages keys in an
# external wallet and submits externally signed raw transactions. Set to 0
# to enable the wallet on node1.
NODE1_DISABLE_WALLET=1

## Mining controller ----------------------------------------------------------
# Address funded with 2x50 BTC at startup.
# Generate a keypair and derive an address, or use the BDK rust crate.
# Helper scripts:
#   keygen:  https://gist.github.com/danielemiliogarcia/c088cc1b0de08a170aa8ff0b01f533b0
#   address: https://gist.github.com/danielemiliogarcia/8b67650ba3ecc6356124741fcf80fb0a
USER_ADDRESS=bcrt1qtmjqjf4t0mcts4jw9hvm54nl2rhjyeclntf3rr
# Seconds between blocks (miners alternate node2/node3)
BLOCK_INTERVAL_SECS=15
# Wallet names created on the miner nodes, also used by the spammer
NODE2_WALLET_NAME=node2
NODE3_WALLET_NAME=node3

## Spammer --------------------------------------------------------------------
ENABLE_SPAM=true
# Total spam txs offered per block — what a block explorer shows per block
# (excess waits in the mempool). The spammer splits it across the miner
# nodes (2,3); how many miners exist is its business, not yours.
SPAM_TXS_PER_BLOCK=100
# How the spam is sent:
#   0     = sequential: one sendtoaddress RPC per tx, so txs hit the mempool
#           one by one, like p2p traffic arriving on a real network node.
#   N > 0 = batch: each spam tx is ONE sendmany with N outputs (~12.7k WU for
#           N=100, an exchange-payout-shaped tx), so one RPC call places N
#           payments. This is the only way to FILL consensus-size (4M WU)
#           blocks on short intervals: sequential sending is bound by RPC
#           round-trips (~20-60 txs/s depending on the machine).
#
# FULL BLOCKS recipes (blocks packed to the 4M WU consensus default):
#   Fast, under 1 minute per block (batch mode):
#     BLOCK_INTERVAL_SECS=60  SPAM_TXS_PER_BLOCK=360  SPAM_SENDMANY_OUTPUTS=100
#     (360 batches x ~12.7k WU ~= 4.6M WU offered per block > 4M cap; the
#      send cycle takes ~40-55s on a mid-range machine, so the occasional
#      block right after a UTXO re-split comes out partial -- use
#      BLOCK_INTERVAL_SECS=90 if every single block must be full.
#      Spam pays burn addresses, so the miner wallets never fill with dust
#      and the send rate stays flat; if blocks still come out partial,
#      measure the cycle with `docker logs -t btc-simnet-spammer` and keep
#      BLOCK_INTERVAL_SECS above it)
#   Sequential p2p-like arrival (SPAM_SENDMANY_OUTPUTS=0): full blocks need
#   the interval to cover ~7100 txs at your machine's send rate:
#     BLOCK_INTERVAL_SECS=420  SPAM_TXS_PER_BLOCK=8000  SPAM_FANOUT_UTXOS=200
#     (~22 tx/s measured on a mid-range desktop -> ~330s minimum; 420s (7 min)
#      leaves reserve for slower machines. Shorter intervals give partially
#      filled blocks: fill% ~= interval * send_rate / 7100)
SPAM_SENDMANY_OUTPUTS=0
# Keep each spam wallet split into this many independent UTXOs, refilling when
# the pool runs low (startup, or after a reorg un-confirms its change). The
# mempool caps unconfirmed tx chains at 25, so a single-UTXO wallet can never
# place more than 25 txs per block; independent UTXOs remove that cap. 0 disables.
SPAM_FANOUT_UTXOS=50
# RBF traffic: true or 1 makes every spam tx signal RBF (BIP125) and, right
# after each batch, fee-bumps the newest SPAM_REPLACES_PER_MINER_PER_BLOCK
# txs per miner (bumpfee), so the mempool carries real replacements (old
# txid evicted, new txid appears). false or 0: same behavior as before.
ENABLE_SPAM_REPLACES=false
SPAM_REPLACES_PER_MINER_PER_BLOCK=5

## Reorg simulator (profile: reorg) -------------------------------------------
# Depth and the block-content style are also passable per run on the command
# line (they override these for that run):
#   ./simulate-reorg.sh 3         # real reorg, re-mines the orphaned txs
#   ./simulate-reorg.sh 3 empty   # chaos: mine empty blocks, txs stay unconfirmed
# How many blocks to orphan per reorg
REORG_DEPTH=3
# once = single reorg then exit | auto = reorg every AUTO_REORG_EVERY_BLOCKS
REORG_MODE=once
# Auto mode cadence; must be greater than REORG_DEPTH
AUTO_REORG_EVERY_BLOCKS=20
# Node used to fork the chain (a miner not exposed to the host is realistic)
REORG_NODE=btc-simnet-node3
# RPC port of REORG_NODE inside the compose network
REORG_NODE_RPC_PORT=18443
# Address that receives the replacement block rewards. NOTE: the default is
# the same address as USER_ADDRESS's default (intentional), so after a reorg
# plus maturity the user balance grows beyond the bootstrap 2x50 BTC. Use a
# separate throwaway address if your test asserts exact user balances.
REORG_MINE_ADDRESS=bcrt1qtmjqjf4t0mcts4jw9hvm54nl2rhjyeclntf3rr
# Orphaned txs return to the mempool and the replacement blocks are filled by
# re-reading the mempool live and mining slices of it, like the winning chain
# of a real reorg (reading it fresh each block also absorbs RBF replacements
# that arrive mid-reorg). On top of that, this many fresh wallet txs are seeded
# into the mempool first, modelling a node that received transactions its peers
# have not yet seen; they are mined into the winning chain alongside the
# returned txs (0 disables). Ignored for `empty` reorgs.
REORG_ADDS_NEW_TXS=5
# Wallet used to send the new txs on the reorg node (falls back to the first
# loaded wallet). Default follows NODE3_WALLET_NAME.
REORG_WALLET_NAME=node3
# Node polled after mining the replacements to confirm the whole network
# adopted the new chain; if the mining controller extended the old chain in
# the meantime (tie), extra blocks are mined (up to 10) until the witness
# follows the new tip. "none" disables the check.
REORG_WITNESS_NODE=btc-simnet-node1

## Tools: electrs (profiles: electrs, mempool, all-tools) ---------------------
ELECTRS_IMAGE=mempool/electrs:v3.3.0
ELECTRS_ELECTRUM_PORT=60001
ELECTRS_HTTP_PORT=3000

## Tools: mempool.space explorer (profiles: mempool, all-tools) ---------------
MEMPOOL_FRONTEND_IMAGE=mempool/frontend:v3.3.1
MEMPOOL_BACKEND_IMAGE=mempool/backend:v3.3.1
MEMPOOL_WEB_PORT=1080
MARIADB_IMAGE=mariadb:10.5.8
MEMPOOL_DB_USER=mempool
MEMPOOL_DB_PASS=mempool
MEMPOOL_DB_ROOT_PASS=admin
