# Simchain, most used settings. Everything is optional: docker-compose.yml
# carries the same defaults, so a missing variable (or no .env at all) works.
#
# Full list of settings: see SETTINGS.md (docs) and .env.full.example (template).

# Bitcoin node image. Default pulls from the registry; to use the locally
# built one instead, run ./docker/build-bitcoin-image.sh and set
# BTC_IMAGE=simchainbitcoinnode:31.1
BTC_IMAGE=bitcoin/bitcoin:31.1
# Bitcoin Core version for the local image build helper (optional; default 31.1)
# BITCOIN_VERSION=31.1

# RPC credentials (shared by all nodes and tools)
BTC_RPC_USER=foo
BTC_RPC_PASS=rpcpassword

# Address funded with 2x50 BTC at startup.
# Generate a keypair and derive an address, or use the BDK rust crate.
# Helper scripts:
#   keygen:  https://gist.github.com/danielemiliogarcia/c088cc1b0de08a170aa8ff0b01f533b0
#   address: https://gist.github.com/danielemiliogarcia/8b67650ba3ecc6356124741fcf80fb0a
USER_ADDRESS=bcrt1qtmjqjf4t0mcts4jw9hvm54nl2rhjyeclntf3rr

# Block pace: bounded exponential intervals between 10 and 20 seconds
BLOCK_INTERVAL_MODE=poisson # options: poisson, fixed (fixed always hits the mean exactly; miner selection is MINER_WEIGHTS in both modes)
BLOCK_INTERVAL_MEAN_SECS=15
BLOCK_INTERVAL_MIN_SECS=10
BLOCK_INTERVAL_MAX_SECS=20
# Relative node2,node3 hashrates; unset means strict alternation
# MINER_WEIGHTS=70,30
# Seed stochastic timing and miner selection for reproducible runs
# MINING_RNG_SEED=42

# Spam so blocks are not empty. This recipe uses the raw engine's DATA/HYBRID
# mode: blocks fill fast with OP_RETURN data txs of varied sizes (near-zero
# node cost, no UTXO-set growth) plus a few small realistic txs, and the
# mempool is kept a couple of blocks deep. See SETTINGS.md "Spammer".
# NOTE: full blocks grow the chain on disk (~1 MB/block, a few GB/day at 10s);
# reset any time with `docker compose down -v`.
ENABLE_SPAM=true
SPAM_TX_DATA_MAX_BYTES=90000   # biggest OP_RETURN payload (fat cheap fill)
SPAM_TX_DATA_MIN_BYTES=250     # spread sizes log-uniformly for a realistic mix
SPAM_SMALL_TXS_PER_BLOCK=40    # small realistic payment-shaped txs per block
SPAM_FLOOR_POOL_TXS=4000       # standing 110-vB floor fills = airtight floor (0 = soft)
SPAM_FILL_BLOCK_RATIO=3        # keep ~2 blocks pending (0.5 half-full .. 5 deep)
SPAM_FEE=0.00015               # 15 sat/vB spam floor; bulk DATA pays a small premium
FALLBACK_FEE=0.00015           # nodes' boot-time -fallbackfee (wallet estimator fallback)
# The branch pool auto-sizes from the ratio (SPAM_FANOUT_AUTO=true by default).
#
# For the old fixed-count spam instead (sequential/batch, wallet-realistic),
# set SPAM_TX_DATA_MAX_BYTES=0 and use SPAM_FIXED_TXS_PER_BLOCK / SPAM_SENDMANY_OUTPUTS.

# Control plane (part of ordinary startup): browser UI + API + MCP on
# http://localhost:8090 (see docs/RETUNING.md)
# CONTROL_PLANE_PORT=8090
# Localhost dev token used by mutating API, MCP, and simchainctl. Override on
# shared machines and pass the same value to host tools with SIMCHAIN_CONTROL_TOKEN.
# CONTROL_PLANE_API_TOKEN=simchain-control-dev-token
# FAUCET_WALLET_RESERVE_BTC=600
# FAUCET_MAX_REQUEST_BTC=100
